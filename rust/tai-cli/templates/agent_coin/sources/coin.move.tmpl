/// Auto-generated by `tai launch`. Module + OTW witness names are
/// randomized at generation time so each launch has a globally-unique coin
/// type. The metadata constants are inlined from the launch flags.
///
/// One-time-witness pattern: the module name lowercased equals the witness
/// struct name uppercased; `init` is called exactly once at publish time
/// and receives the OTW instance, which it forwards to
/// `coin::create_currency` to produce a fresh `TreasuryCap<T>`.
module agent_coin::{{MODULE_NAME}} {
    use sui::coin;
    use sui::transfer;
    use sui::url;

    /// One-time witness for this coin module. Same name as the module,
    /// uppercased. Sui's runtime ensures `init` is called exactly once
    /// with the singleton instance of this struct.
    public struct {{WITNESS_NAME}} has drop {}

    /// Initializer. Creates the currency, sends both caps to the address
    /// baked into the template at generation time — typically the tai-cli
    /// signer that will chain `launch_agent_coin<T>` in the next tx.
    ///
    /// `tai launch` shells out to `sui client publish` (which uses the sui
    /// CLI's active address) then runs `launch_agent_coin` via tai-core
    /// (which uses tai-cli's signer). For the second tx to succeed, the
    /// signer must own the freshly-minted caps — so we transfer them
    /// directly to that address from init, not to `ctx.sender()`.
    fun init(otw: {{WITNESS_NAME}}, ctx: &mut TxContext) {
        let (treasury_cap, metadata) = coin::create_currency<{{WITNESS_NAME}}>(
            otw,
            {{DECIMALS}}u8,
            b"{{SYMBOL}}",
            b"{{NAME_BYTES}}",
            b"{{DESCRIPTION_BYTES}}",
            option::some(url::new_unsafe_from_bytes(b"{{ICON_URL_BYTES}}")),
            ctx,
        );
        let recipient = @{{CAPS_RECIPIENT}};
        transfer::public_transfer(metadata, recipient);
        transfer::public_transfer(treasury_cap, recipient);
    }
}
